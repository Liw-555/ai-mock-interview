# ──────────────────────────────────────────────
# LLM 对话模型配置（必填）
# ──────────────────────────────────────────────
# 支持 OpenAI 兼容格式的任何 API 提供商
# 推荐：ECNU Plus / 智谱 GLM / DeepSeek / OpenAI

# API 基础地址（以 /v1 结尾）
LLM_BASE_URL=https://chat.ecnu.edu.cn/open/api/v1
# 你的 API Key
LLM_API_KEY=sk-your-api-key-here
# 模型名称
LLM_MODEL=ecnu-plus

# ──────────────────────────────────────────────
# 嵌入模型配置（P1 阶段 RAG 功能需要，MVP 可不填）
# ──────────────────────────────────────────────
# 推荐：SiliconFlow BAAI/bge-m3（免费额度可用）

EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=

# ──────────────────────────────────────────────
# 数据库（默认 SQLite，无需修改）
# ──────────────────────────────────────────────
# DATABASE_URL=sqlite:///./data/interview_agent.db
